generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model LotteryType {
  id        String          @id @default(cuid())
  code      String          @unique
  name      String
  shortName String
  category  LotteryCategory
  region    LotteryRegion
  drawDays  Int[]
  drawTime  String
  isActive  Boolean         @default(true)
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  draws     Draw[]
  provinces Province[]

  @@map("lottery_types")
}

model Province {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  shortName     String
  region        LotteryRegion
  lotteryTypeId String
  drawDayOfWeek Int?
  isActive      Boolean       @default(true)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  draws         Draw[]
  lotteryType   LotteryType   @relation(fields: [lotteryTypeId], references: [id])

  @@index([lotteryTypeId])
  @@index([region])
  @@map("provinces")
}

model Draw {
  id            String      @id @default(cuid())
  drawDate      DateTime
  drawNumber    Int?
  lotteryTypeId String
  provinceId    String?
  isComplete    Boolean     @default(false)
  crawledAt     DateTime?
  crawlSource   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  lotteryType   LotteryType @relation(fields: [lotteryTypeId], references: [id])
  province      Province?   @relation(fields: [provinceId], references: [id])

  specialCodes    String[]

  lotoResults   LotoResult?
  results       Result[]
  vietlottPrizes  VietlottPrize[] 

  @@unique([drawDate, lotteryTypeId, provinceId])
  @@index([drawDate])
  @@index([lotteryTypeId])
  @@index([lotteryTypeId, drawDate])
  @@index([drawDate, lotteryTypeId])
  @@map("draws")
}

model Result {
  id        String    @id @default(cuid())
  drawId    String
  prizeName PrizeName
  numbers   String[]
  headNums  Int[]
  tailNums  Int[]
  createdAt DateTime  @default(now())
  draw      Draw      @relation(fields: [drawId], references: [id], onDelete: Cascade)

  @@index([drawId])
  @@index([drawId, prizeName])
  @@index([tailNums])
  @@map("results")
}

model LotoResult {
  id           String   @id @default(cuid())
  drawId       String   @unique
  head0        Int[]
  head1        Int[]
  head2        Int[]
  head3        Int[]
  head4        Int[]
  head5        Int[]
  head6        Int[]
  head7        Int[]
  head8        Int[]
  head9        Int[]
  allTwoDigits Int[]
  createdAt    DateTime @default(now())
  draw         Draw     @relation(fields: [drawId], references: [id], onDelete: Cascade)

  @@index([drawId])
  @@map("loto_results")
}

model StatCache {
  id            String   @id @default(cuid())
  lotteryTypeId String
  statType      String
  data          Json
  computedAt    DateTime @default(now())
  validUntil    DateTime

  @@unique([lotteryTypeId, statType])
  @@index([lotteryTypeId])
  @@index([validUntil])
  @@map("stat_cache")
}

model CrawlLog {
  id              String   @id @default(cuid())
  lotteryTypeId   String
  targetDate      DateTime
  source          String
  status          String
  recordsInserted Int      @default(0)
  errorMessage    String?
  executionMs     Int?
  createdAt       DateTime @default(now())

  @@index([lotteryTypeId])
  @@index([createdAt])
  @@index([status])
  @@map("crawl_logs")
}

enum PrizeName {
  DB
  G1
  G2
  G3
  G4
  G5
  G6
  G7
  JP1
  JP2
  VL1
  VL2
  VL3
  VL4
  VL5
  KENO
}

enum LotteryRegion {
  MIEN_BAC
  MIEN_NAM
  MIEN_TRUNG
  VIETLOTT
}

enum LotteryCategory {
  XSKT
  MEGA645
  POWER655
  MAX3D
  MAX3DPRO
  KENO
}

model VietlottPrize {
  id        String   @id @default(cuid())
  drawId    String
  draw      Draw     @relation(fields: [drawId], references: [id], onDelete: Cascade)
  name      String   // "Jackpot 1", "Jackpot 2", "Giải nhất", "Giải nhì"...
  winners   Int      @default(0)
  value     String   // "52,121,608,950" — lưu string vì số rất lớn
  createdAt DateTime @default(now())

  @@index([drawId])
  @@map("vietlott_prizes")
}